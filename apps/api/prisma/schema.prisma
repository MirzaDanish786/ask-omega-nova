generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum UserRole {
  ADMIN
  ALL_ACCESS
  ANALYST
  VIEWER
}

enum CrisisLevel {
  STABLE
  ELEVATED
  HIGH
  CRITICAL
  CATASTROPHIC
}

enum EarlyWarningSeverity {
  STABLE
  ELEVATED
  HIGH
  CRITICAL
  SYSTEMIC
}

enum SimulationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum AgentStatus {
  ACTIVE
  PAUSED
  ERROR
  DISABLED
}

// ============ AUTH (BetterAuth) ============

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    Boolean   @default(false)
  name             String
  image            String?
  role             UserRole  @default(VIEWER)
  assignedModules  String[]  @default([])
  companyId        String?
  monthlySimCount  Int       @default(0)
  simRateLimit     Int       @default(50)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company       ClientCompany? @relation(fields: [companyId], references: [id])
  sessions      Session[]
  accounts      Account[]
  simulations   Simulation[]
  notifications Notification[]
  auditLogs     AuditLog[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============ OGWI ============

model OgwiHistoricalData {
  id               String      @id @default(cuid())
  date             DateTime
  ogwiScore        Float
  crisisLevel      CrisisLevel
  regionalHotspots String[]    @default([])
  forecast         Json?
  microDeltaCi     Float       @default(0)
  microDeltaRss    Float       @default(0)
  microDeltaMomentum Float     @default(0)
  hmmRegime        String      @default("normal")
  netSignalDirection String    @default("neutral")
  consecutiveEscalatoryUpdates Int @default(0)
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([date])
}

model Osd12Composite {
  id         String   @id @default(cuid())
  date       DateTime
  hmmRegime  String
  ogwiInput  Float
  indicators Json?
  createdAt  DateTime @default(now())

  @@index([date])
}

// ============ SIMULATIONS ============

model Simulation {
  id             String           @id @default(cuid())
  userId         String
  query          String
  status         SimulationStatus @default(PENDING)
  threadId       String?
  answer         String?
  tokensUsed     Int              @default(0)
  ogwiSnapshot   Float?
  kbArticlesUsed String[]         @default([])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model KnowledgeBaseArticle {
  id          String   @id @default(cuid())
  title       String
  category    String
  text        String
  tags        String[] @default([])
  keywords    String[] @default([])
  accessLevel String   @default("standard")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============ EARLY WARNING ============

model EarlyWarningData {
  id        String               @id @default(cuid())
  region    String
  score     Float
  severity  EarlyWarningSeverity
  signals   Json?
  drivers   String[]             @default([])
  createdAt DateTime             @default(now())

  @@index([region])
  @@index([createdAt])
}

// ============ AGENTS ============

model AgentConfig {
  id         String      @id @default(cuid())
  agentId    String      @unique
  name       String
  enabled    Boolean     @default(true)
  status     AgentStatus @default(ACTIVE)
  schedule   String
  lastRunAt  DateTime?
  errorCount Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  auditLogs AgentAuditLog[]
}

model AgentAuditLog {
  id         String   @id @default(cuid())
  agentId    String
  action     String
  status     String
  durationMs Int      @default(0)
  error      String?
  createdAt  DateTime @default(now())

  agent AgentConfig @relation(fields: [agentId], references: [agentId])

  @@index([agentId])
}

// ============ NOTIFICATIONS & AUDIT ============

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  severity  String   @default("info")
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  details    Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

// ============ CLIENT COMPANY ============

model ClientCompany {
  id             String @id @default(cuid())
  name           String
  logoUrl        String?
  primaryColor   String @default("#1e40af")
  secondaryColor String @default("#3b82f6")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users User[]
}
